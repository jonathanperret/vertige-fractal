{
  "name": "vertige-fractal",
  "version": "1.3.1",
  "private": true,
  "homepage": ".",
  "dependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "twgl.js": "^7.0.0",
    "typescript": "^6.0.2"
  },
  "devDependencies": {
    "gh-pages": "^6.3.0",
    "prettier": "^3.8.1",
    "standard-version": "^9.5.0",
    "vite": "^6.3.5",
    "@vitejs/plugin-react": "^4.7.0"
  },
  "scripts": {
    "start": "vite",
    "start:https": "vite --https",
    "build": "vite build",
    "build:ci": "CI=true npm run build",
    "build:localhost": "vite build --base=./",
    "test": "echo \"No tests configured\"",
    "test:ci": "npm run test",
    "predeploy": "npm run build",
    "deploy": "npm run predeploy && gh-pages -d dist",
    "lint": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "lint:fix": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "release": "standard-version",
    "release:patch": "npm run release -- --release-as patch"
  }
}
